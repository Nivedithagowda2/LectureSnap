# ── Backblaze B2 ──────────────────────────────
GROQ_API_KEY=Your_GROQ_API_KEY_here
# ── OpenAI (ONLY needed for audio/video transcription) ────────
# PDF uploads work WITHOUT this — only needed for .mp3/.mp4 files
#OPENAI_API_KEY=your_openai_api_key_here

# Get these from: https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=Your_B2_Key_ID_here
B2_APP_KEY=Your_App_Key_here
B2_BUCKET_NAME=Your_B2_Bucket_Name_here

# Your B2 endpoint — found in your bucket details page
# Format: https://s3.{region}.backblazeb2.com
# Example: https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=Your_B2_Endpoint_here

# ── OpenAI (for Whisper transcription) ────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=Your_OpenAI_API_Key_Here

# ── ElevenLabs (Step 5 — Teacher Voice) ───────────────────────
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=Your_ELEVENLABS_API_KEY_here
# Voice ID — Rachel (warm, conversational). Change in ElevenLabs dashboard.
ELEVENLABS_VOICE_ID=Your_ELEVENLABS_VOICE_ID_here
